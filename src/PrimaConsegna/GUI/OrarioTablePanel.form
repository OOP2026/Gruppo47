<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="GUI.OrarioTablePanel">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      
      <!-- PANNELLO SUPERIORE PER I FILTRI (North) -->
      <grid id="topPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="96994" class="javax.swing.JLabel">
            <constraints/>
            <properties>
              <text value="Filtra per anno:"/>
            </properties>
          </component>
          <component id="a1e7a" class="javax.swing.JComboBox" binding="filtroAnnoBox">
            <constraints/>
            <properties/>
          </component>
        </children>
      </grid>

      <!-- TABELLA ESPANSA AL CENTRO (Center) -->
      <scrollpane id="3ff23">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="ce05c" class="javax.swing.JTable" binding="table">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
      
    </children>
  </grid>
</form>
