<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="GUI.MainFrame">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="862" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <!-- BARRA DI NAVIGAZIONE IN ALTO (North) -->
      <grid id="75fae" layout-manager="GridLayoutManager" row-count="1" column-count="6" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="5" left="5" bottom="5" right="5"/>
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="ecce5" class="javax.swing.JButton" binding="btnOrario">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Orario Generale"/>
            </properties>
          </component>
          <component id="c3ae2" class="javax.swing.JButton" binding="btnCreaLezione">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Crea Lezione"/>
            </properties>
          </component>
          <component id="484dd" class="javax.swing.JButton" binding="btnRisorse">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Aule &amp; Insegnamenti"/>
            </properties>
          </component>
          <component id="75696" class="javax.swing.JButton" binding="btnRichieste">
            <constraints>
              <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Gestisci Richieste"/>
            </properties>
          </component>
          <component id="4fc43" class="javax.swing.JButton" binding="btnInviaReq">
            <constraints>
              <grid row="0" column="4" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Invia Richiesta"/>
            </properties>
          </component>
          <component id="9f359" class="javax.swing.JButton" binding="btnStudente">
            <constraints>
              <grid row="0" column="5" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Orario Studente"/>
            </properties>
          </component>
        </children>
      </grid>
      
      <!-- PANNELLO CENTRALE VUOTO PER LE CARTE (Center) -->
      <grid id="d9bb8" binding="contentPanel" layout-manager="CardLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children/>
      </grid>
    </children>
  </grid>
</form>
